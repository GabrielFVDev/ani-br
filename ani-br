version_info() {
    printf "%s\n" "$version_number"
    exit 0
}

update_script() {
    printf "[branch:%s] Checking for Update..\n" "$branch"
    update="$(curl --fail-with-body -sL -A "$agent" "https://raw.githubusercontent.com/pystardust/ani-cli/$branch/ani-cli")" || die "[branch:$branch] Connection error: $update"
    printf '%s' "$update" | grep -q "^version_number" || die "[branch:$branch] Invalid Response."
    update="$(printf '%s\n' "$update" | diff -u "$0" -)"
    if [ -z "$update" ]; then
        printf "[branch:%s] Script is up to date :)\n" "$branch"
    else
        if printf '%s\n' "$update" | patch "$0" -; then
            printf "[branch:%s] Script has been updated\n" "$branch"
        else
            die "[branch:$branch] Can't update for some reason!"
        fi
    fi
    exit 0
}

# checks if dependencies are present
dep_ch() {
    for dep; do
        command -v "${dep%% *}" >/dev/null || die "Program \"${dep%% *}\" not found. Please install it."
    done
}

where_iina() {
    [ -e "/Applications/IINA.app/Contents/MacOS/iina-cli" ] && echo "/Applications/IINA.app/Contents/MacOS/iina-cli" && return 0
    printf "%s" "iina" && return 0
}

where_mpv() {
    command -v "flatpak" >/dev/null && flatpak info io.mpv.Mpv >/dev/null 2>&1 && printf "%s" "flatpak_mpv" && return 0
    printf "%s" "mpv" && return 0
}

cleanup() {
    [ "$player_function" = "android_mpv" ] && : >"/storage/emulated/0/mpv/mpv.config.mp4"
    printf "\033[0m"        # clears colors
    rm -f "${histfile}.new" # remove temp logfile
}

# SCRAPING
#
# Fontes plugaveis. Cada fonte implementa tres funcoes com o mesmo contrato:
#   <fonte>_search "<consulta>"        -> linhas: id_nativo<TAB>titulo
#   <fonte>_episodes "<id_nativo>"     -> um numero de episodio por linha
#   <fonte>_episode_url "<id>" "<ep>"  -> linhas: <qualidade> ><url>
# Os dispatchers abaixo percorrem $sources por prioridade e carimbam o id com
# "<fonte>:", para que historico (-c) e fallback saibam a origem.

search_anime() {
    for _src in $sources; do
        _results=$("${_src}_search" "$1")
        [ -z "$_results" ] && continue
        printf '%s\n' "$_results" | sed "s|^|${_src}:|"
        return 0
    done
}

episodes_list() {
    _src=${1%%:*}
    "${_src}_episodes" "${1#*:}"
}

get_episode_url() {
    _src=${id%%:*}
    links=$("${_src}_episode_url" "${id#*:}" "$ep_no")
    if printf "%s" "$ep_list" | grep -q "^$ep_no$"; then
        [ -z "$links" ] && die "Episodio liberado, mas sem fontes validas!"
    else
        [ -z "$links" ] && die "Episodio nao disponivel!"
    fi
    select_quality "$quality"
    # referer = base da fonte + "/" (alguns CDNs exigem; inofensivo nos demais)
    eval "_base=\"\${${_src}_base:-}\""
    if [ -n "$_base" ]; then
        refr_flag="--referrer=${_base}/"
        m3u8_refr="${_base}/"
    else
        unset refr_flag
    fi
    # alguns provedores HLS servem segmentos com extensao falsa (.webp); mpv/ffmpeg novos
    # rejeitam por extension_picky -> desliga so nessas fontes (inofensivo nas demais)
    case "$_src" in
        animesdigital | topanimes) src_play_opts="--demuxer-lavf-o=extension_picky=0" ;;
        *) src_play_opts="" ;;
    esac
}

select_quality() {
    case "$1" in
        best) result=$(printf "%s" "$links" | head -n1) ;;
        worst) result=$(printf "%s" "$links" | grep -E '^[0-9]' | tail -n1) ;;
        *) result=$(printf "%s" "$links" | grep -m 1 "$1") ;;
    esac
    [ -z "$result" ] && printf "Qualidade '%s' nao encontrada, usando a melhor disponivel\n" "$1" 1>&2 && result=$(printf "%s" "$links" | head -n1)

    episode=$(printf "%s" "$result" | cut -d'>' -f2)
}

# --- Fonte: AnimeFire (animefire.plus) ---
# Paginas HTML: /pesquisar/{consulta} e /animes/{slug}-todos-os-episodios
# Video (JSON): /video/{slug}/{ep} -> {"data":[{"src","label"}],"response":{"status"}}

animefire_search() {
    # o main separa palavras com '+'; o AnimeFire usa '-'
    _query=$(printf '%s' "$1" | tr '+ ' '--')
    _results=$(curl -sL -A "$agent" "$animefire_base/pesquisar/$_query" |
        sed 's|<a href="[^"]*/animes/|\n|g' |
        sed -nE 's|^([a-z0-9-]+)-todos-os-episodios">.*animeTitle">([^<]*)</h3>.*|\1\t\2|p')
    # --dub mantem apenas as entradas dubladas (slug termina em -dublado);
    # o titulo ja vem rotulado com "(Dublado)" pelo proprio site
    [ "$mode" = "dub" ] && _results=$(printf '%s' "$_results" | grep -- '-dublado')
    printf '%s' "$_results"
}

animefire_episodes() {
    curl -sL -A "$agent" "$animefire_base/animes/$1-todos-os-episodios" |
        grep -oE "/animes/$1/[0-9]+(\.[0-9]+)?" |
        sed 's|.*/||' | sort -n -u
}

animefire_episode_url() {
    # $1 = slug, $2 = episodio
    _resp=$(curl -sL -A "$agent" -e "$animefire_base/" \
        -H "X-Requested-With: XMLHttpRequest" "$animefire_base/video/$1/$2")
    # status 500 / corpo vazio => episodio inexistente ou indisponivel
    printf '%s' "$_resp" | grep -q '"status":"200"' || return 0
    # data[].src ja e link direto (.mp4/.m3u8 do lightspeedst; googlevideo p/ Blogger)
    printf '%s' "$_resp" | jq -r '.data[]? | "\(.label) >\(.src)"' 2>/dev/null | sort -nr
}

# --- Fonte: AnimesROLL (anroll.info) ---
# Busca: /search/?q={q}; Serie: /anime/{slug}
# Episodio: /anime/{slug}/temporada-{T}/episodio-{NNN}; o video e um HLS .m3u8
# montado a partir do urlConfig (texto puro) da pagina do episodio.

# lista ordenada (ordem de exibicao) dos fragmentos temporada-T/episodio-N da serie
_anroll_eplist() {
    curl -sL -A "$agent" "$anroll_base/anime/$1" |
        grep -oE 'temporada-[0-9]+/episodio-[0-9]+' | sort -u |
        sed -E 's|temporada-([0-9]+)/episodio-([0-9]+)|\1 \2 &|' |
        sort -k1,1n -k2,2n | sed 's|^[0-9]* [0-9]* ||'
}

anroll_search() {
    # titulo/tag derivados do slug (o data-title do site e inconsistente e nao marca dublado)
    curl -sL -A "$agent" "$anroll_base/search/?q=$1" |
        grep -oE 'href="[^"]*/anime/[a-z0-9-]+"' |
        sed -E 's|.*/anime/([a-z0-9-]+)".*|\1|' | sort -u |
        while IFS= read -r _slug; do
            if [ "$mode" = "dub" ]; then
                case "$_slug" in *-dublado) ;; *) continue ;; esac
            fi
            case "$_slug" in
                *-dublado) _tag=" (Dublado)" ;;
                *-legendado) _tag=" (Legendado)" ;;
                *) _tag="" ;;
            esac
            _name=$(printf '%s' "$_slug" | sed -E 's/-(dublado|legendado)$//; s/-/ /g')
            printf '%s\t%s%s\n' "$_slug" "$_name" "$_tag"
        done
}

anroll_episodes() {
    # indice global 1..N (temporadas achatadas em ordem de exibicao)
    _anroll_eplist "$1" | grep -n '' | cut -d: -f1
}

anroll_episode_url() {
    # $1 = slug, $2 = indice global do episodio (1..N)
    _frag=$(_anroll_eplist "$1" | sed -n "${2}p")
    [ -z "$_frag" ] && return 0
    _html=$(curl -sL -A "$agent" -e "$anroll_base/" "$anroll_base/anime/$1/$_frag")
    _b=$(printf '%s' "$_html" | grep -oE 'base: *"[^"]*"' | head -1 | sed -E 's/.*"([^"]*)".*/\1/')
    _t=$(printf '%s' "$_html" | grep -oE 'temporada: *[0-9]+' | head -1 | grep -oE '[0-9]+')
    _e=$(printf '%s' "$_html" | grep -oE 'episodio: *[0-9]+' | head -1 | grep -oE '[0-9]+')
    { [ -z "$_b" ] || [ -z "$_t" ] || [ -z "$_e" ]; } && return 0
    _p=$(printf '%s' "$1" | cut -c1 | tr 'a-z' 'A-Z')
    printf 'HLS >%s/%s/%s/%02d-temporada/%02d/stream.m3u8\n' "$_b" "$_p" "$1" "$_t" "$_e"
}

# --- Fonte: AnimesDigital (animesdigital.org) ---
# Busca: /?s={q}. Serie: /anime/a/{slug} faz 301 -> codigo curto canonico; episodios
# paginados em /anime/a/{code}/page/{N}/ (50/pag, pagina vazia = fim, mais novo primeiro).
# Video: /video/a/{vid} tem iframe api.anivideo.net/videohls.php?d={m3u8} -> HLS direto
# (CDN serve segmentos disfarcados de .webp -> exige extension_picky=0 no playback).

animesdigital_search() {
    _results=$(curl -sL -A "$agent" "$animesdigital_base/?s=$1" |
        grep -oE 'href="[^"]*/anime/a/[a-z0-9-]+" title="Assistir [^"]*"' |
        sed -nE 's|.*/anime/a/([a-z0-9-]+)" title="Assistir (.*) Online em HD".*|\1\t\2|p' |
        awk -F'\t' '!seen[$1]++')
    # --dub mantem so os titulos rotulados "Dublado" (sub mostra tudo, igual animefire/anroll)
    [ "$mode" = "dub" ] && _results=$(printf '%s' "$_results" | grep -i 'Dublado')
    printf '%s' "$_results"
}

# ids de video (vid) em ordem crescente de episodio (indice plano 1..N, igual ao anroll)
_animesdigital_eplist() {
    _code=$(curl -sL -A "$agent" -o /dev/null -w '%{url_effective}' "$animesdigital_base/anime/a/$1" |
        sed -E 's#.*/anime/a/([^/?]+).*#\1#')
    [ -z "$_code" ] && _code="$1"
    _page=1
    _all=""
    while [ "$_page" -le 60 ]; do
        _vids=$(curl -sL -A "$agent" "$animesdigital_base/anime/a/$_code/page/$_page/" |
            grep -oE '/video/a/[A-Za-z0-9]+' | sed 's|/video/a/||')
        [ -z "$_vids" ] && break
        _all="$_all$_vids
"
        _page=$((_page + 1))
    done
    # a listagem vem do mais novo p/ o mais antigo: dedup preservando ordem e inverter
    printf '%s' "$_all" | awk 'NF && !seen[$0]++ {a[++n]=$0} END{for (i=n;i>=1;i--) print a[i]}'
}

animesdigital_episodes() {
    _animesdigital_eplist "$1" | grep -n '' | cut -d: -f1
}

animesdigital_episode_url() {
    # $1 = slug, $2 = indice global do episodio (1..N)
    _vid=$(_animesdigital_eplist "$1" | sed -n "${2}p")
    [ -z "$_vid" ] && return 0
    _m=$(curl -sL -A "$agent" -e "$animesdigital_base/" "$animesdigital_base/video/a/$_vid/" |
        grep -oE 'videohls\.php\?d=[^"&]+' | head -1 | sed 's/.*d=//')
    [ -z "$_m" ] && return 0
    printf 'HLS >%s\n' "$_m"
}

# --- Fonte: TopAnimes (topanimes.net) ---
# WordPress/DooPlay. Busca: /?s={q}. Serie: /animes/{slug} lista /episodio/{slug}-episodio-{N}.
# Video: admin-ajax doo_player_ajax (post+nume) -> embed por tipo; resolvemos os que dao HLS:
#   anidigital (= anivideo videohls.php?d=m3u8), mk ("file":"...m3u8" no corpo do embed),
#   sk-api (embed + &mode=api2 -> JSON .midias[].url). Demais (bg/Blogger, ruplay...) ignorados.

topanimes_search() {
    curl -sL -A "$agent" "$topanimes_base/?s=$1" |
        grep -oE 'href="[^"]*/(animes|filmes)/[a-z0-9-]+/"' |
        sed -nE 's#.*/(animes|filmes)/([a-z0-9-]+)/".*#\2#p' | awk '!seen[$0]++' |
        while IFS= read -r _slug; do
            # idioma pelo sufixo do slug: -dublado / -japones (legendado) / base
            if [ "$mode" = "dub" ]; then
                case "$_slug" in *-dublado) ;; *) continue ;; esac
            fi
            case "$_slug" in
                *-dublado) _tag=" (Dublado)" ;;
                *-japones) _tag=" (Legendado)" ;;
                *) _tag="" ;;
            esac
            _name=$(printf '%s' "$_slug" | sed -E 's/-(dublado|japones)$//; s/-/ /g')
            printf '%s\t%s%s\n' "$_slug" "$_name" "$_tag"
        done
}

topanimes_episodes() {
    curl -sL -A "$agent" "$topanimes_base/animes/$1/" |
        grep -oE "/episodio/$1-episodio-[0-9]+/" |
        sed -nE 's|.*-episodio-([0-9]+)/|\1|p' | sort -nu
}

topanimes_episode_url() {
    # $1 = slug, $2 = numero do episodio
    _ep="$topanimes_base/episodio/$1-episodio-$2/"
    _eh=$(curl -sL -A "$agent" "$_ep")
    _post=$(printf '%s' "$_eh" | grep -oE "data-post='[0-9]+'" | head -1 | grep -oE '[0-9]+')
    [ -z "$_post" ] && return 0
    for _n in $(printf '%s' "$_eh" | grep -oE "data-nume='[0-9]+'" | grep -oE '[0-9]+' | sort -un); do
        _r=$(curl -sL -A "$agent" -e "$_ep" \
            --data "action=doo_player_ajax&post=$_post&nume=$_n&type=tv" \
            "$topanimes_base/wp-admin/admin-ajax.php")
        _emb=$(printf '%s' "$_r" | jq -r '.embed_url // empty' 2>/dev/null)
        [ -z "$_emb" ] && continue
        case "$(printf '%s' "$_r" | jq -r '.type // empty' 2>/dev/null)" in
            anidigital) _m=$(printf '%s' "$_emb" | sed 's/.*videohls\.php?d=//; s/&.*//') ;;
            mk) _m=$(curl -sL -A "$agent" -e "$_ep" "$_emb" |
                grep -oE '"file": *"[^"]*\.m3u8[^"]*"' | head -1 | sed -E 's/"file": *"//; s/"$//') ;;
            sk-api) _m=$(curl -sL -A "$agent" -e "$topanimes_base/" "${_emb}&mode=api2" |
                jq -r '.midias[]?.url // empty' 2>/dev/null | head -1) ;;
            *) _m="" ;;
        esac
        [ -n "$_m" ] && printf 'HLS >%s\n' "$_m"
    done
}

time_until_next_ep() {
    animeschedule="https://animeschedule.net"
    query="$(printf "%s\n" "$*" | tr ' ' '+')"
    curl -s -G "$animeschedule/api/v3/anime" --data "q=${query}" | sed 's|"id"|\n|g' | sed -nE 's|.*,"route":"([^"]*)","premier.*|\1|p' | while read -r anime; do
        data=$(curl -s "$animeschedule/anime/$anime" | sed '1,/"anime-header-list-buttons-wrapper"/d' | sed -nE 's|.*countdown-time-raw" datetime="([^"]*)">.*|Next Raw Release: \1|p;s|.*countdown-time" datetime="([^"]*)">.*|Next Sub Release: \1|p;s|.*english-title">([^<]*)<.*|English Title: \1|p;s|.*main-title".*>([^<]*)<.*|Japanese Title: \1|p')
        status="Ongoing"
        color="33"
        printf "%s\n" "$data"
        ! (printf "%s\n" "$data" | grep -q "Next Raw Release:") && status="Finished" && color="32"
        printf "Status:  \033[1;%sm%s\033[0m\n---\n" "$color" "$status"
    done
    exit 0
}

# PLAYING

process_hist_entry() {
    ep_list=$(episodes_list "$id")
    latest_ep=$(printf "%s\n" "$ep_list" | tail -n1)
    title=$(printf "%s\n" "$title" | sed "s|[0-9]\+ episodes|${latest_ep} episodes|")
    ep_no=$(printf "%s" "$ep_list" | sed -n "/^${ep_no}$/{n;p;}") 2>/dev/null
    [ -n "$ep_no" ] && printf "%s\t%s - episode %s\n" "$id" "$title" "$ep_no"
}

update_history() {
    if grep -q -- "$id" "$histfile"; then
        sed -E "s|^[^	]+	${id}	[^	]+$|${ep_no}	${id}	${title}|" "$histfile" >"${histfile}.new"
    else
        cp "$histfile" "${histfile}.new"
        printf "%s\t%s\t%s\n" "$ep_no" "$id" "$title" >>"${histfile}.new"
    fi
    mv "${histfile}.new" "$histfile"
}

download() {
    case $1 in
        *m3u8*)
            if command -v "yt-dlp" >/dev/null; then
                yt-dlp --referer "$m3u8_refr" "$1" --no-skip-unavailable-fragments --fragment-retries infinite -N 16 -o "$download_dir/$2.mp4"
            else
                ffmpeg -extension_picky 0 -referer "$m3u8_refr" -loglevel error -stats -i "$1" -c copy "$download_dir/$2.mp4"
            fi
            ;;
        *)
            # shellcheck disable=SC2086
            aria2c --referer="${refr_flag#--referrer=}" --enable-rpc=false --check-certificate=false --continue $iSH_DownFix --summary-interval=0 -x 16 -s 16 "$1" --dir="$download_dir" -o "$2.mp4" --download-result=hide
            ;;
    esac
}

android_mpv() {
    dir="/storage/emulated/0/mpv"
    file="$dir/mpv.config.mp4"
    if [ -w "${dir%*/mpv}" ]; then
        [ -d "${dir}" ] || mkdir "${dir}"
        printf "%s" "$3" | sed 's| --|\n|g; s|^--||g' >"$file"
    fi
    am start --user 0 -a android.intent.action.VIEW -d "$1" -n is.xyz.mpv/.MPVActivity -e "title" "$2" >/dev/null 2>&1
    unset dir file
}

play_episode() {
    [ "$log_episode" = 1 ] && [ "$player_function" != "debug" ] && [ "$player_function" != "download" ] && command -v logger >/dev/null && logger -t ani-br "${media_title}${ep_no}"
    [ "$skip_intro" = 1 ] && skip_flag="$(ani-skip -q "$mal_id" -e "$ep_no")"
    [ -z "$episode" ] && get_episode_url
    # shellcheck disable=SC2086
    case "$player_function" in
        debug)
            printf "All links:\n%s\nSelected link:\n" "$links"
            printf "%s\n" "$episode"
            ;;
        mpv*)
            if [ "$no_detach" = 0 ]; then
                nohup $player_function $skip_flag $src_play_opts --tls-verify=no --force-media-title="${media_title}Episode ${ep_no}" "$episode" $refr_flag >/dev/null 2>&1 &
            else
                $player_function $skip_flag $src_play_opts $refr_flag --tls-verify=no --force-media-title="${media_title}Episode ${ep_no}" "$episode"
                mpv_exitcode=$?
                [ "$exit_after_play" = 1 ] && [ -z "$range" ] && exit "$mpv_exitcode"
            fi
            ;;
        android_mpv) "$player_function" "$episode" "${media_title}Episode ${ep_no}" "--tls-verify=no $refr_flag" 2>&1 & ;;
        android_vlc) nohup am start --user 0 -a android.intent.action.VIEW -d "$episode" -n org.videolan.vlc/org.videolan.vlc.gui.video.VideoPlayerActivity -e "title" "${media_title}Episode ${ep_no}" >/dev/null 2>&1 & ;;
        *iina*)
            [ -n "$refr_flag" ] && refr_flag="--mpv-${refr_flag#--}"
            if pgrep -f "IINA" >/dev/null 2>&1; then
                # omit --keep-running when an IINA instance exists to prevent hanging
                nohup $player_function --no-stdin --mpv-tls-verify=no --mpv-force-media-title="${media_title}Episode ${ep_no}" $refr_flag "$episode" >/dev/null 2>&1 &
            else
                nohup $player_function --no-stdin --mpv-tls-verify=no --keep-running --mpv-force-media-title="${media_title}Episode ${ep_no}" $refr_flag "$episode" >/dev/null 2>&1 &
            fi
            ;;
        flatpak_mpv) flatpak run io.mpv.Mpv $src_play_opts --tls-verify=no --force-media-title="${media_title}Episode ${ep_no}" "$episode" $refr_flag >/dev/null 2>&1 & ;;
        vlc*) nohup $player_function --http-referrer="${refr_flag#--referrer=}" --play-and-exit --meta-title="${media_title}Episode ${ep_no}" "$episode" >/dev/null 2>&1 & ;;
        *yncpla*) nohup $player_function "$episode" -- --tls-verify=no --force-media-title="${media_title}Episode ${ep_no}" $refr_flag >/dev/null 2>&1 & ;;
        download) "$player_function" "$episode" "${media_title}Episode ${ep_no}" ;;
        catt) nohup catt cast "$episode" >/dev/null 2>&1 & ;;
        iSH)
            printf "\e]8;;vlc://%s\a~~~~~~~~~~~~~~~~~~~~\n~ Tap to open VLC ~\n~~~~~~~~~~~~~~~~~~~~\e]8;;\a\n" "$episode"
            sleep 5
            ;;
        *) nohup $player_function "$episode" >/dev/null 2>&1 & ;;
    esac
    replay="$episode"
    unset episode
    update_history
    [ "$use_external_menu" = "1" ] && wait
    [ "$use_external_menu" = "2" ] && wait
}

play() {
    start=$(printf "%s" "$ep_no" | grep -Eo '^(-1|[0-9]+(\.[0-9]+)?)')
    end=$(printf "%s" "$ep_no" | grep -Eo '(-1|[0-9]+(\.[0-9]+)?)$')
    [ "$start" = "-1" ] && ep_no=$(printf "%s" "$ep_list" | tail -n1) && unset start
    [ -z "$end" ] || [ "$end" = "$start" ] && unset start end
    [ "$end" = "-1" ] && end=$(printf "%s" "$ep_list" | tail -n1)
    line_count=$(printf "%s\n" "$ep_no" | wc -l | tr -d "[:space:]")
    if [ "$line_count" != 1 ] || [ -n "$start" ]; then
        [ -z "$start" ] && start=$(printf "%s\n" "$ep_no" | head -n1)
        [ -z "$end" ] && end=$(printf "%s\n" "$ep_no" | tail -n1)
        range=$(printf "%s\n" "$ep_list" | sed -nE "/^${start}\$/,/^${end}\$/p")
        [ -z "$range" ] && die "Invalid range!"
        for i in $range; do
            tput clear
            ep_no=$i
            printf "\33[2K\r\033[1;34mPlaying episode %s...\033[0m\n" "$ep_no"
            [ "$i" = "$end" ] && unset range
            play_episode
        done
    else
        play_episode
    fi
    # moves up to stored position and deletes to end
    [ "$player_function" != "debug" ] && [ "$player_function" != "download" ] && tput rc && tput ed
}

# MAIN

# setup
agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:150.0) Gecko/20100101 Firefox/150.0"
animefire_base="${ANI_CLI_ANIMEFIRE_BASE:-https://animefire.io}"
anroll_base="${ANI_CLI_ANROLL_BASE:-https://www.anroll.info}"
animesdigital_base="${ANI_CLI_ANIMESDIGITAL_BASE:-https://animesdigital.org}"
topanimes_base="${ANI_CLI_TOPANIMES_BASE:-https://topanimes.net}"
sources="${ANI_CLI_SOURCES:-animesdigital anroll animefire topanimes}"
mode="${ANI_CLI_MODE:-sub}"
download_dir="${ANI_CLI_DOWNLOAD_DIR:-.}"
log_episode="${ANI_CLI_LOG:-1}"
quality="${ANI_CLI_QUALITY:-best}"
case "$(uname -a | cut -d " " -f 1,3-)" in
    *Darwin*) player_function="${ANI_CLI_PLAYER:-$(where_iina)}" ;;   # mac OS
    *ndroid*) player_function="${ANI_CLI_PLAYER:-android_mpv}" ;;     # Android OS (termux)
    *MINGW* | *WSL2*) player_function="${ANI_CLI_PLAYER:-mpv.exe}" ;; # Windows OS
    *ish*) player_function="${ANI_CLI_PLAYER:-iSH}" ;;                # iOS (iSH)
    *) player_function="${ANI_CLI_PLAYER:-$(where_mpv)}" ;;           # Linux OS
esac

no_detach="${ANI_CLI_NO_DETACH:-0}"
exit_after_play="${ANI_CLI_EXIT_AFTER_PLAY:-0}"
use_external_menu="${ANI_CLI_EXTERNAL_MENU:-0}"
external_menu_normal_window="${ANI_CLI_EXTERNAL_MENU_NORMAL_WINDOW:-0}"
skip_intro="${ANI_CLI_SKIP_INTRO:-0}"
skip_title="${ANI_CLI_SKIP_TITLE:-}"
[ -t 0 ] || (command -v dmenu && use_external_menu=2)
[ -t 0 ] || (command -v rofi && use_external_menu=1)
hist_dir="${ANI_CLI_HIST_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/ani-br}"
[ ! -d "$hist_dir" ] && mkdir -p "$hist_dir"
histfile="$hist_dir/ani-hsts"
[ ! -f "$histfile" ] && : >"$histfile"
search="${ANI_CLI_DEFAULT_SOURCE:-scrape}"
branch="${ANI_CLI_BRANCH:-master}"

while [ $# -gt 0 ]; do
    case "$1" in
        -v | --vlc)
            case "$(uname -a | cut -d " " -f 1,3-)" in
                *ndroid*) player_function="android_vlc" ;;
                MINGW* | *WSL2*) player_function="vlc.exe" ;;
                *ish*) player_function="iSH" ;;
                *) player_function="vlc" ;;
            esac
            ;;
        -s | --syncplay)
            case "$(uname -s)" in
                Darwin*) player_function="/Applications/Syncplay.app/Contents/MacOS/syncplay" ;;
                MINGW* | *Msys)
                    export PATH="$PATH":"/c/Program Files (x86)/Syncplay/"
                    player_function="syncplay.exe"
                    ;;
                *) player_function="syncplay" ;;
            esac
            ;;
        -q | --quality)
            [ $# -lt 2 ] && die "missing argument!"
            quality="$2"
            shift
            ;;
        -S | --select-nth)
            [ $# -lt 2 ] && die "missing argument!"
            index="$2"
            shift
            ;;
        -c | --continue) search=history ;;
        -d | --download)
            [ "$player_function" = "iSH" ] && iSH_DownFix="--async-dns=false"
            player_function=download
            ;;
        -D | --delete)
            : >"$histfile"
            exit 0
            ;;
        -l | --logview)
            case "$(uname -s)" in
                Darwin*) log show --predicate 'process == "logger"' ;;
                Linux*) journalctl -t ani-br ;;
                *) die "Logger not implemented for your platform" ;;
            esac
            exit 0
            ;;
        -V | --version) version_info ;;
        -h | --help) help_info ;;
        -e | --episode | -r | --range)
            [ $# -lt 2 ] && die "missing argument!"
            ep_no="$2"
            shift
            ;;
        --dub) mode="dub" ;;
        --no-detach) no_detach=1 ;;
        --exit-after-play) exit_after_play=1 && no_detach=1 ;;
        --rofi) use_external_menu=1 ;;
        --dmenu) use_external_menu=2 ;;
        --skip) skip_intro=1 ;;
        --skip-title)
            [ $# -lt 2 ] && die "missing argument!"
            skip_title="$2"
            shift
            ;;
        -N | --nextep-countdown) search=nextep ;;
        -U | --update)
            branch="${2:-$branch}"
            update_script
            ;;
        *) query="$(printf "%s" "$query $1" | sed "s|^ ||;s| |+|g")" ;;
    esac
    shift
done
[ "$use_external_menu" = "0" ] && multi_selection_flag="${ANI_CLI_MULTI_SELECTION:-"-m"}"
[ "$use_external_menu" = "1" ] && multi_selection_flag="${ANI_CLI_MULTI_SELECTION:-"-multi-select"}"
[ "$external_menu_normal_window" = "1" ] && external_menu_args="-normal-window"
printf "\33[2K\r\033[1;34mChecking dependencies...\033[0m\n"
dep_ch "curl" "sed" "grep" || true
dep_ch "jq" || true
[ "$skip_intro" = 1 ] && (dep_ch "ani-skip" || true)
dep_ch "fzf" || true
case "$player_function" in
    debug) ;;
    download) dep_ch "ffmpeg" "aria2c" ;;
    android*) printf "\33[2K\rChecking of players on Android is disabled.\nANI-CLI recommends Android MPV for full compatibility.\nAdd:\n include='/storage/emulated/0/mpv/mpv.config.mp4'\nto:\n MPV > Settings > Advanced > mpv.conf\nfor full functionality.\nIgnore, If Done.\n" ;;
    *iSH*) printf "\33[2K\rChecking of players on iOS is disabled\n" ;;
    flatpak_mpv) true ;; # handled out of band in where_mpv
    *) dep_ch "$player_function" ;;
esac

# idk where to put this, so I put it here...
trap 'cleanup; exit 1' INT HUP

# searching
case "$search" in
    history)
        anime_list=$(while read -r ep_no id title; do process_hist_entry & done <"$histfile")
        wait
        [ -z "$anime_list" ] && die "No unwatched series in history!"
        [ -z "${index##*[!0-9]*}" ] && id=$(printf "%s" "$anime_list" | nl -w 2 | sed 's/^[[:space:]]//' | nth "Select anime: " | cut -f1)
        [ -z "${index##*[!0-9]*}" ] || id=$(printf "%s" "$anime_list" | sed -n "${index}p" | cut -f1)
        [ -z "$id" ] && exit 1
        title=$(printf "%s" "$anime_list" | grep "$id" | cut -f2 | sed 's/ - episode.*//')
        ep_list=$(episodes_list "$id")
        ep_no=$(printf "%s" "$anime_list" | grep "$id" | cut -f2 | sed -nE 's/.*- episode (.+)$/\1/p')
        media_title="$(printf "%s" "$title" | cut -d'(' -f1 | tr -d '[:punct:]')"
        ;;
    *)
        if [ "$use_external_menu" = "0" ]; then
            while [ -z "$query" ]; do
                printf "\33[2K\r\033[1;36mSearch anime: \033[0m" && read -r query
            done
        else
            [ -z "$query" ] && query=$(printf "" | external_menu "" "Search anime: " "$external_menu_args")
            [ -z "$query" ] && exit 1
        fi
        # for checking new releases by specifying anime name
        [ "$search" = "nextep" ] && time_until_next_ep "$query"

        query=$(printf "%s" "$query" | sed "s| |+|g")
        anime_list=$(search_anime "$query")
        [ -z "$anime_list" ] && die "No results found!"
        [ "$index" -eq "$index" ] 2>/dev/null && result=$(printf "%s" "$anime_list" | sed -n "${index}p")
        [ -z "$index" ] && result=$(printf "%s" "$anime_list" | nl -w 2 | sed 's/^[[:space:]]//' | nth "Select anime: ")
        [ -z "$result" ] && exit 1
        title=$(printf "%s" "$result" | cut -f2)
        media_title="$(printf "%s" "$title" | cut -d'(' -f1 | tr -d '[:punct:]')"
        id=$(printf "%s" "$result" | cut -f1)
        ep_list=$(episodes_list "$id")
        [ -z "$ep_no" ] && ep_no=$(printf "%s" "$ep_list" | nth "Select episode: " "$multi_selection_flag")
        [ -z "$ep_no" ] && exit 1
        ;;
esac
[ "$skip_intro" = 1 ] && mal_id="$(ani-skip -q "${skip_title:-${title}}")"

# moves the cursor up one line and clears that line
tput cuu1 && tput el
# stores the position of cursor
tput sc

# playback & loop
play
[ "$player_function" = "download" ] || [ "$player_function" = "debug" ] && exit 0

while cmd=$(printf "next\nreplay\nprevious\nselect\nchange_quality\nquit" | nth "Playing episode $ep_no of $title... "); do
    case "$cmd" in
        next) ep_no=$(printf "%s" "$ep_list" | sed -n "/^${ep_no}$/{n;p;}") 2>/dev/null ;;
        replay) episode="$replay" ;;
        previous) ep_no=$(printf "%s" "$ep_list" | sed -n "/^${ep_no}$/{g;1!p;};h") 2>/dev/null ;;
        select) ep_no=$(printf "%s" "$ep_list" | nth "Select episode: " "$multi_selection_flag") ;;
        change_quality)
            new_quality="$(printf "%s" "$links" | launcher | cut -d\> -f1)"
            select_quality "$new_quality"
            ;;
        *)
            cleanup
            exit 0
            ;;
    esac
    [ -z "$ep_no" ] && die "Out of range"
    play
done

